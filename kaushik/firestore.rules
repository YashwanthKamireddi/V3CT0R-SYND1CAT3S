// Enhanced Firestore Security Rules for Campus Pulse
// Works with client-side services (no Cloud Functions needed)

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper Functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return request.auth.uid == userId;
    }
    
    function isOrganizer() {
      return isSignedIn() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['organizer', 'admin'];
    }

    // --- USERS ---
    match /users/{userId} {
      // Any signed-in user can read user profiles (for leaderboards)
      allow read: if isSignedIn();
      
      // Users can create their own profile
      allow create: if isOwner(userId) && 
        request.resource.data.uid == userId &&
        request.resource.data.points == 0 &&
        request.resource.data.registeredEventIds == [] &&
        request.resource.data.attendedEventIds == [];
      
      // Users can update their own profile (except protected fields)
      allow update: if isOwner(userId) && 
        // Don't allow direct manipulation of points, registeredEventIds, attendedEventIds, role
        (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['points', 'role']) ||
         // Allow incrementing points (for attendance - simple validation)
         (request.resource.data.points >= resource.data.points));
    }

    // --- EVENTS ---
    match /events/{eventId} {
      // Anyone can read events (public)
      allow read: if true;
      
      // Only organizers can create events
      allow create: if isSignedIn();
      
      // Organizers can update their own events, or anyone can update counts
      allow update: if isSignedIn() && (
        // Event owner can update anything
        resource.data.organizerId == request.auth.uid ||
        // Anyone can increment registration counts
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['registeredCount', 'waitlistCount', 'attendees'])
      );
      
      // Only event owner can delete
      allow delete: if isSignedIn() && resource.data.organizerId == request.auth.uid;
    }

    // --- REGISTRATIONS ---
    match /registrations/{registrationId} {
      // Users can read their own registrations
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      
      // Users can create registrations for themselves
      allow create: if isSignedIn() && 
        request.resource.data.userId == request.auth.uid &&
        request.resource.data.status in ['confirmed', 'waitlisted'] &&
        request.resource.data.attended == false;
      
      // Users can update their own registrations (cancel, mark attended)
      allow update: if isSignedIn() && 
        resource.data.userId == request.auth.uid;
    }

    // --- REWARDS ---
    match /rewards/{rewardId} {
      // Anyone can read rewards
      allow read: if true;
      
      // Only admins can manage rewards
      allow write: if isSignedIn() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // --- REWARD REDEMPTIONS ---
    match /redemptions/{redemptionId} {
      // Users can read their own redemptions
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      
      // Users can create redemptions for themselves
      allow create: if isSignedIn() && 
        request.resource.data.userId == request.auth.uid &&
        request.resource.data.status == 'pending';
    }
  }
}
